{
  "name": "continuum",
  "version": "0.1.0",
  "private": true,
  "description": "A multilingual Socratic tutor reachable from any phone.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "chat": "tsx src/cli/chat.ts",
    "curriculum:brief:check": "tsx src/cli/check-curriculum-brief.ts",
    "curriculum:brief:review": "tsx src/cli/review-curriculum-brief.ts",
    "curriculum:compile": "tsx src/cli/compile-curriculum.ts",
    "curriculum:review:packet": "tsx scripts/generate-curriculum-review.ts",
    "curriculum:verify": "tsx src/cli/verify-curriculum.ts",
    "curriculum:freeze": "tsx src/cli/freeze-curriculum.ts",
    "curriculum:release:check": "tsx src/cli/check-curriculum-release.ts --target curriculum/releases/india-grade6.json",
    "diagnostic": "tsx src/cli/diagnostic.ts",
    "eval": "tsx src/evals/run.ts",
    "eval:live": "tsx src/evals/live-run.ts",
    "eval:live-history": "tsx src/evals/live-history-run.ts",
    "eval:live-safety": "tsx src/evals/live-safety-run.ts",
    "eval:live-sandbox": "tsx src/evals/live-sandbox-run.ts",
    "eval:live-placement": "tsx src/evals/live-placement-run.ts",
    "eval:agents": "tsx src/evals/agent/run.ts",
    "smoke:realtime": "tsx src/cli/realtime-smoke.ts",
    "sample:audio": "tsx scripts/generate-sample-audio.ts",
    "seed:demo": "tsx src/cli/seed-demo.ts",
    "smoke:production": "tsx scripts/verify-production.ts",
    "phone:preflight": "tsx src/cli/phone-preflight.ts",
    "release:preflight": "tsx scripts/release-preflight.ts",
    "release:verify": "npm run verify:fresh",
    "secrets:init": "tsx src/cli/init-secrets.ts",
    "start": "tsx src/server.ts",
    "start:prod": "node dist/start-production.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test",
    "verify:fresh": "tsx scripts/verify-fresh-clone.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.2.3",
    "openai": "^6.9.1",
    "ws": "^8.21.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
