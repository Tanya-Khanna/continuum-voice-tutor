{
  "name": "continuum",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.3",
  "description": "A multilingual Socratic tutor reachable from any phone.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tanya-Khanna/nomad-ai.git"
  },
  "homepage": "https://continuum-production-8971.up.railway.app/",
  "bugs": {
    "url": "https://github.com/Tanya-Khanna/nomad-ai/issues"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "chat": "tsx src/cli/chat.ts",
    "eval": "tsx src/evals/open-topic-run.ts",
    "eval:live": "tsx src/evals/open-topic-live-run.ts",
    "eval:live-safety": "tsx src/evals/open-topic-live-run.ts --category safety",
    "sample:audio": "tsx scripts/generate-sample-audio.ts",
    "seed:demo": "tsx src/cli/seed-demo.ts",
    "smoke:production": "tsx scripts/verify-production.ts",
    "phone:preflight": "tsx src/cli/phone-preflight.ts",
    "release:preflight": "tsx scripts/release-preflight.ts",
    "release:verify": "npm run verify:fresh",
    "secrets:init": "tsx src/cli/init-secrets.ts",
    "guardian:enroll": "tsx src/cli/enroll-guardian.ts",
    "start": "tsx src/server.ts",
    "start:prod": "node dist/start-production.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test",
    "lint": "tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "format:check": "tsx scripts/check-format.ts",
    "verify": "npm run format:check && npm run lint && npm run check && npm run eval && npm run build && npm run smoke:production",
    "verify:fresh": "tsx scripts/verify-fresh-clone.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.2.3",
    "openai": "^6.9.1",
    "twilio": "^6.0.2",
    "ws": "^8.21.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
