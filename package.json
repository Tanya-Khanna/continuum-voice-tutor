{
  "name": "nomad-ai",
  "version": "0.1.0",
  "private": true,
  "description": "A multilingual Socratic tutor reachable from any phone.",
  "type": "module",
  "scripts": {
    "chat": "tsx src/cli/chat.ts",
    "diagnostic": "tsx src/cli/diagnostic.ts",
    "eval": "tsx src/evals/run.ts",
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.2.3",
    "openai": "^6.9.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
