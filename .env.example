# Offline mode is the default and needs no credentials.
TEACHING_ENGINE=offline
PORT=3000
NOMAD_DATABASE_PATH=.data/nomad.db
NOMAD_PHONE_HASH_SECRET=local-development-change-me
# Point this at any schema-valid compiled deployment pack. Blank uses the built-in India fractions demo.
NOMAD_CURRICULUM_PATH=
NOMAD_MAX_CALLS_PER_HOUR=6

# Enable only after API credits are available.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.6-luna
OPENAI_REALTIME_MODEL=gpt-realtime-2.1-mini
OPENAI_REALTIME_VOICE=marin
OPENAI_WEBHOOK_SECRET=

# Configure only after the Twilio paid upgrade and SIP trunk exist.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
OPENAI_PROJECT_ID=
