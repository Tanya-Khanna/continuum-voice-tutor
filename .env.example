# Offline mode is the default and needs no credentials.
TEACHING_ENGINE=offline
HOST=0.0.0.0
PORT=3000
NOMAD_DATABASE_PATH=.data/nomad.db
NOMAD_PHONE_HASH_SECRET=local-development-change-me
NOMAD_LEARNER_CODE_SECRET=local-learner-code-change-me
NOMAD_GUARDIAN_CODE_SECRET=local-guardian-code-change-me
NOMAD_CALLBACK_SECRET=local-callback-change-me
NOMAD_PUBLIC_BASE_URL=
NOMAD_RELEASE_COMMIT=
# Set true only after every final carrier behavior passes and the number is approved for publication.
NOMAD_PUBLIC_PHONE_ENABLED=false
NOMAD_MISSED_CALL_ENABLED=false
NOMAD_MISSED_CALL_ADULT_DEMO=false
NOMAD_SMS_CONTROLS_ENABLED=false
NOMAD_SMS_REMINDERS_ENABLED=false
NOMAD_SMS_REMINDER_INTERVAL_MS=30000
NOMAD_SCHEDULER_ENABLED=false
NOMAD_SCHEDULER_INTERVAL_MS=30000
NOMAD_CALLBACK_ALLOWED_PREFIXES=["+1","+91"]
NOMAD_DEPLOYMENT_TIME_ZONE=Asia/Kolkata
NOMAD_CALLBACK_QUIET_START_HOUR=21
NOMAD_CALLBACK_QUIET_END_HOUR=7
NOMAD_CALLBACK_PER_NUMBER_DAILY_LIMIT=3
NOMAD_CALLBACK_GLOBAL_DAILY_LIMIT=100
# Point this at any schema-valid compiled deployment pack. Blank uses the built-in India fractions demo.
NOMAD_CURRICULUM_PATH=
# For a multi-subject deployment, leave NOMAD_CURRICULUM_PATH blank and provide an ordered JSON array of frozen pack paths. Use builtin:india-ncert-grade-6-fractions for the checked-in flagship. The first entry is the default/Sandbox context.
NOMAD_CURRICULUM_PATHS=
NOMAD_AGENT_EVAL_REPORT_PATH=.data/latest-agent-eval.json
NOMAD_OPEN_TOPIC_LIVE_EVAL_REPORT_PATH=.data/latest-open-topic-live-eval.json
NOMAD_MAX_CALLS_PER_HOUR=6
# Optional locally; required before this server is public. Minimum 24 characters. Share via a URL fragment, never a query string.
NOMAD_DASHBOARD_TOKEN=

# Enable only after API credits are available.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.6-luna
OPENAI_COMPILER_MODEL=gpt-5.6-terra
OPENAI_VERIFIER_MODEL=gpt-5.6-terra
OPENAI_REALTIME_MODEL=gpt-realtime-2.1-mini
OPENAI_REALTIME_VOICE=marin
# Realtime playback multiplier: 0.8 is twenty percent slower than default.
OPENAI_REALTIME_SPEED=0.8
# Provisional phone-call VAD values; tune only from measured real calls.
NOMAD_VAD_THRESHOLD=0.5
NOMAD_VAD_PREFIX_PADDING_MS=300
NOMAD_VAD_SILENCE_MS=650
OPENAI_SPEECH_MODEL=tts-1-hd
OPENAI_WEBHOOK_SECRET=
OPENAI_PROJECT_ID=
# Set true only after the signed webhook is reachable over public HTTPS.
NOMAD_OPENAI_WEBHOOK_PUBLIC=false

# Configure only after the Twilio paid upgrade and SIP trunk exist.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MISSED_CALL_NUMBER=
# Operator attestations; the app cannot infer Twilio console state from secrets.
NOMAD_TWILIO_SIP_TRUNK_CONFIGURED=false
NOMAD_TWILIO_NUMBER_VOICE_READY=false
# Compatibility flag for outbound lesson messaging. Keep off until the deployment has explicit consent for reviewed homework and pause notices on that exact phone.
NOMAD_SMS_RECAP_ENABLED=false
